{
  "name": "kook-codex-bridge",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').mkdirSync('dist/apps/club-system/src/db',{recursive:true});require('fs').copyFileSync('apps/club-system/src/db/schema.sql','dist/apps/club-system/src/db/schema.sql')\"",
    "start": "node dist/src/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^17.2.3",
    "hono": "^4.6.0",
    "ws": "^8.18.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.10.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
