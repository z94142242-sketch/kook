# ===== 共享 KOOK Bot =====
# 一个 Bot，两套功能（Codex bridge + club-system）共用同一个 Gateway 连接。
KOOK_BOT_TOKEN=
KOOK_API_BASE=https://www.kookapp.cn/api/v3

# ===== Codex bridge（必填）=====
KOOK_ALLOWED_USER_ID=
KOOK_ALLOWED_CHANNEL_ID=
CODEX_COMMAND_PREFIXES=/codex,/c
CODEX_DEFAULT_PROJECT=bridge
CODEX_APPROVAL_POLICY=on-request
CODEX_MAX_CONCURRENT_TASKS=1
KOOK_MESSAGE_MAX_LENGTH=1800
CODEX_TASK_TIMEOUT_MS=600000

# ===== Club system（可选）=====
# 设为 true 才会启动俱乐部功能 + HTTP API（小程序用）。
# 设为 false（默认）= 进程退化成纯 Codex bridge，跟以前一样。
CLUB_ENABLED=false

# 以下 CLUB_* 仅在 CLUB_ENABLED=true 时使用
CLUB_GUILD_ID=
CLUB_COMMAND_CHANNEL_ID=
CLUB_STANDBY_VOICE_CHANNEL_ID=
CLUB_ADMIN_USER_IDS=
CLUB_COMMAND_PREFIXES=/club,/cm
CLUB_DB_PATH=./data/club.db

# HTTP API（给小程序调用）
CLUB_HTTP_ENABLED=true
CLUB_HTTP_PORT=3000
CLUB_HTTP_HOST=0.0.0.0
CLUB_DEV_LOGIN_ENABLED=false
CLUB_SESSION_TTL_HOURS=720

# 微信小程序
CLUB_WX_APP_ID=
CLUB_WX_APP_SECRET=
