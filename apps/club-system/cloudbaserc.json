{
  "envId": "",
  "framework": {
    "name": "kook-club-system",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "club-system",
          "servicePath": "/club-system",
          "localPath": "./",
          "uploadType": "package",
          "dockerfile": "Dockerfile",
          "buildDir": "./",
          "containerPort": 3000,
          "minNum": 1,
          "maxNum": 1,
          "cpu": 0.25,
          "mem": 0.5,
          "policyType": "cpu",
          "policyThreshold": 80,
          "envParams": {
            "CLUB_KOOK_BOT_TOKEN": "",
            "CLUB_GUILD_ID": "",
            "CLUB_COMMAND_CHANNEL_ID": "",
            "CLUB_STANDBY_VOICE_CHANNEL_ID": "",
            "CLUB_ADMIN_USER_IDS": "",
            "CLUB_DB_PATH": "/app/data/club.db",
            "CLUB_HTTP_ENABLED": "true",
            "CLUB_HTTP_PORT": "3000",
            "CLUB_HTTP_HOST": "0.0.0.0",
            "CLUB_DEV_LOGIN_ENABLED": "false",
            "CLUB_WX_APP_ID": "",
            "CLUB_WX_APP_SECRET": ""
          },
          "volumeMounts": [
            {
              "name": "club-data",
              "mountPath": "/app/data",
              "readOnly": false
            }
          ]
        }
      }
    }
  }
}
