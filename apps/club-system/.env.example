# KOOK Bot
CLUB_KOOK_BOT_TOKEN=
CLUB_KOOK_API_BASE=https://www.kookapp.cn/api/v3

# 工作室所在的服务器 / Guild ID
CLUB_GUILD_ID=

# 命令频道（员工发命令、看卡片的文字频道）
CLUB_COMMAND_CHANNEL_ID=

# 待命语音房：员工上班后挂机的地方
CLUB_STANDBY_VOICE_CHANNEL_ID=

# 管理员的 KOOK 用户 ID 列表，逗号分隔
CLUB_ADMIN_USER_IDS=

# 命令前缀，逗号分隔。默认 /club, /cm
CLUB_COMMAND_PREFIXES=/club,/cm

# 数据文件路径，默认 ./data/club.db
CLUB_DB_PATH=./data/club.db

# ---- HTTP API（给小程序调用）-----
CLUB_HTTP_ENABLED=true
CLUB_HTTP_PORT=3000
CLUB_HTTP_HOST=0.0.0.0

# 开发用：本地无需真微信也能登录（生产必须关掉）
CLUB_DEV_LOGIN_ENABLED=false

# 会话有效期（小时），默认 30 天
CLUB_SESSION_TTL_HOURS=720

# ---- 微信小程序 -----
CLUB_WX_APP_ID=
CLUB_WX_APP_SECRET=
